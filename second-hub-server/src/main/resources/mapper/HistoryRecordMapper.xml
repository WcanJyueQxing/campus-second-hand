<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nie.secondhub.mapper.HistoryRecordMapper">

    <!-- 按用户ID和浏览时间倒序查询历史记录 -->
    <select id="selectByUserIdOrderByViewTimeDesc" resultType="com.nie.secondhub.entity.HistoryRecord">
        SELECT * FROM history_record
        WHERE user_id = #{userId}
        ORDER BY view_time DESC
        LIMIT #{limit}
    </select>

    <!-- 按用户ID和商品ID删除历史记录 -->
    <delete id="deleteByUserIdAndGoodsId">
        DELETE FROM history_record
        WHERE user_id = #{userId} AND goods_id = #{goodsId}
    </delete>

    <!-- 按用户ID删除所有历史记录 -->
    <delete id="deleteByUserId">
        DELETE FROM history_record
        WHERE user_id = #{userId}
    </delete>

</mapper>