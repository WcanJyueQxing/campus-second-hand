<view class="mine-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info" bindtap="toProfileEdit">
      <image class="avatar" src="{{avatarUrl || 'https://img.yzcdn.cn/vant/cat.jpeg'}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="username">{{isLoggedIn ? nickname : '未登录'}}</text>
        <text class="welcome-text">{{isLoggedIn ? '欢迎回来，看看今天有什么新发布' : '登录后可同步收藏、发布和订单数据'}}</text>
      </view>
      <view class="arrow"></view>
    </view>
    <view class="login-btn-wrapper" wx:if="{{!isLoggedIn}}">
      <button class="login-btn" bindtap="toLogin">一键登录</button>
    </view>
  </view>

  <!-- 我的交易模块 -->
  <view class="trade-card" wx:if="{{isLoggedIn}}">
    <view class="trade-title">我的交易</view>
    <view class="trade-items">
      <view class="trade-item" bindtap="toPublish">
        <view class="trade-icon icon-publish">
          <text class="icon-text">📦</text>
        </view>
        <text class="trade-label">发布</text>
        <text class="trade-count">{{publishCount || 0}}</text>
      </view>
      <view class="trade-item" bindtap="toSoldOrders">
        <view class="trade-icon icon-sold">
          <text class="icon-text">💰</text>
        </view>
        <text class="trade-label">卖出</text>
        <text class="trade-count">{{soldCount || 0}}</text>
      </view>
      <view class="trade-item" bindtap="toBoughtOrders">
        <view class="trade-icon icon-bought">
          <text class="icon-text">🛒</text>
        </view>
        <text class="trade-label">买到</text>
        <text class="trade-count">{{boughtCount || 0}}</text>
      </view>
      <view class="trade-item" bindtap="toPendingReviews">
        <view class="trade-icon icon-review">
          <text class="icon-text">⭐</text>
        </view>
        <text class="trade-label">待评价</text>
        <text class="trade-count">{{reviewCount || 0}}</text>
      </view>
    </view>
  </view>

  <!-- 功能列表模块 -->
  <view class="function-card">
    <view class="function-item" bindtap="toFavorites">
      <text class="function-label">我的收藏</text>
      <view class="arrow"></view>
    </view>
    <view class="function-divider"></view>
    <view class="function-item" bindtap="toHistory">
      <text class="function-label">历史浏览</text>
      <view class="arrow"></view>
    </view>
    <view class="function-divider"></view>
    <view class="function-item" bindtap="toMyGoods">
      <text class="function-label">我的发布</text>
      <view class="arrow"></view>
    </view>
    <view class="function-divider"></view>
    <view class="function-item" bindtap="toSettings">
      <text class="function-label">设置</text>
      <view class="arrow"></view>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-wrapper" wx:if="{{isLoggedIn}}">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>