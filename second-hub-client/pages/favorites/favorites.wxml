<view class="container">
  <!-- 列表 -->
  <view wx:if="{{list.length > 0}}" class="list">
    <view wx:for="{{list}}" wx:key="id" class="item" bindtap="goDetail" data-id="{{item.id}}">
      <image class="cover" src="{{item.coverImage}}" mode="aspectFill" />
      <view class="info">
        <text class="title">{{item.title}}</text>
        <text class="price">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <text>你还没有收藏商品</text>
    <text>去首页逛逛，把喜欢的宝贝收藏起来吧</text>
  </view>
</view>