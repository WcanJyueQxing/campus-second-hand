/* 全局样式重置 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.login-page {
  padding: 60rpx 40rpx;
}

/* Logo 区域 */
.logo-area {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #66b1ff 0%, #409eff 100%);
  color: #fff;
  font-size: 72rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(64, 158, 255, 0.3);
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 32rpx;
  color: #909399;
}

/* 登录卡片 */
.login-card {
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  border-bottom: 1rpx solid #ebeef5;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 32rpx 0;
  font-size: 32rpx;
  color: #606266;
  position: relative;
}

.tab-item.active {
  color: #409eff;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background-color: #409eff;
  border-radius: 2rpx;
}

/* 表单区域 */
.form-area {
  padding: 40rpx;
}

/* 输入框样式 */
.input-item {
  display: flex;
  align-items: center;
  height: 88rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 8rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  background-color: #fff;
  transition: all 0.3s;
  position: relative;
}

.input-item:focus-within {
  border-color: #409eff;
  box-shadow: 0 0 0 4rpx rgba(64, 158, 255, 0.1);
}

.input-icon {
  margin-right: 16rpx;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Element UI 风格图标 */
.icon-user {
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #909399;
  border-radius: 50%;
  opacity: 0.7;
}

.icon-lock {
  position: relative;
  width: 16rpx;
  height: 12rpx;
  border: 3rpx solid #909399;
  border-bottom: none;
  border-radius: 2rpx 2rpx 0 0;
  opacity: 0.7;
}

.icon-lock::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #909399;
  border-radius: 2rpx;
}

.icon-verification {
  position: relative;
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid #909399;
  border-radius: 4rpx;
  opacity: 0.7;
}

.icon-verification::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10rpx;
  height: 10rpx;
  background: #909399;
  border-radius: 2rpx;
}

.input-field {
  flex: 1;
  font-size: 32rpx;
  color: #303133;
  padding-right: 100rpx;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: #c0c4cc;
}

/* 验证码行 */
.captcha-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.captcha-input {
  flex: 3;
  margin-bottom: 0;
  margin-right: 16rpx;
}

.captcha-img-wrapper {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 8rpx;
  background-color: #f5f7fa;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  overflow: hidden;
}

.captcha-img {
  width: 100%;
  height: 100%;
}

.captcha-placeholder {
  font-size: 24rpx;
  color: #909399;
}

/* 记住密码 */
.remember-item {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.remember-label {
  display: flex;
  align-items: center;
}

.remember-checkbox {
  margin-right: 16rpx;
}

.remember-text {
  font-size: 28rpx;
  color: #606266;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 88rpx;
  background-color: #409eff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 34rpx;
  font-weight: 500;
  border: none;
  transition: background-color 0.3s;
}

.login-btn:active {
  background-color: #3a8ee6;
}

.login-btn:disabled {
  background-color: #c6e2ff;
  color: #fff;
  cursor: not-allowed;
}

/* 昵称输入框容器 */
.nickname-input-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 8rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background-color: #fff;
  margin-bottom: 24rpx;
  transition: all 0.3s;
}

.nickname-input-wrap:focus-within {
  border-color: #409eff;
  box-shadow: 0 0 0 4rpx rgba(64, 158, 255, 0.1);
}

/* 昵称输入框 */
.nickname-input {
  flex: 1;
  font-size: 32rpx;
  color: #303133;
  margin-right: 16rpx;
}

.nickname-input::placeholder {
  color: #c0c4cc;
}

/* 随机按钮 */
.random-btn {
  flex-shrink: 0;
  font-size: 30rpx;
  color: #409eff;
  font-weight: 500;
  transition: opacity 0.3s;
}

.random-btn:active {
  opacity: 0.7;
}

/* 微信登录 */
.wechat-login {
  text-align: center;
}

.wechat-hint {
  font-size: 32rpx;
  color: #606266;
  margin-bottom: 32rpx;
}

.avatar-hint {
  font-size: 28rpx;
  color: #909399;
  margin: 16rpx 0 40rpx;
}

.wechat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.wechat-icon {
  width: 36rpx;
  height: 36rpx;
  background: #07c160;
  border-radius: 8rpx;
  position: relative;
}

.wechat-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 16rpx;
  border: 3rpx solid #ffffff;
  border-radius: 2rpx;
  border-top: none;
}

.wechat-icon::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #ffffff;
  border-radius: 50%;
}

/* 加载状态 */
.login-btn[loading] {
  opacity: 0.7;
}

/* 禁用状态 */
.input-item--disabled {
  border-color: #ebeef5;
  background-color: #f5f7fa;
}

.input-field:disabled {
  color: #c0c4cc;
  cursor: not-allowed;
}