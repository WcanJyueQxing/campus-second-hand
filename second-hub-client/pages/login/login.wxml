<view class="container login-page">
  <view class="login-header">
    <view class="logo-wrapper">
      <view class="logo-icon">S</view>
    </view>
    <view class="app-name">Second Hub</view>
    <view class="app-slogan">校园二手交易平台</view>
  </view>

  <view class="panel login-form">
    <view class="tab-wrapper">
      <view class="tab-item {{currentTab === 'account' ? 'active' : ''}}" bindtap="switchTab" data-tab="account">
        账号登录
      </view>
      <view class="tab-item {{currentTab === 'wechat' ? 'active' : ''}}" bindtap="switchTab" data-tab="wechat">
        微信登录
      </view>
    </view>

    <view class="tab-content">
      <block wx:if="{{currentTab === 'account'}}">
        <view class="form-item">
          <view class="input-wrapper">
            <view class="input-icon icon-user"></view>
            <input
              class="input-control"
              type="text"
              placeholder="请输入用户名/手机号"
              value="{{account}}"
              bindinput="onAccountInput"
              disabled="{{loading}}"
            />
          </view>
        </view>

        <view class="form-item">
          <view class="input-wrapper">
            <view class="input-icon icon-lock"></view>
            <input
              class="input-control"
              password
              placeholder="请输入密码"
              value="{{password}}"
              bindinput="onPasswordInput"
              disabled="{{loading}}"
            />
          </view>
        </view>

        <view class="form-item remember-row">
          <checkbox-group bindchange="onRememberChange">
            <label class="remember-label">
              <checkbox value="remember" checked="{{remember}}" color="#2f7df6" />
              <text class="remember-text">记住密码</text>
            </label>
          </checkbox-group>
        </view>

        <button class="primary-btn login-btn" bindtap="accountLogin" loading="{{loading}}" disabled="{{loading}}">
          {{loading ? '登录中...' : '登录'}}
        </button>
      </block>

      <block wx:if="{{currentTab === 'wechat'}}">
        <view class="wechat-login-wrapper">
          <view class="nickname-hint">一键授权，快速登录</view>

          <view class="form-item">
            <view class="input-wrapper">
              <view class="input-icon icon-nickname"></view>
              <input
                class="input-control"
                placeholder="请输入昵称（选填）"
                value="{{nickname}}"
                bindinput="onNicknameInput"
                disabled="{{loading}}"
              />
            </view>
          </view>

          <view class="avatar-hint">微信授权将自动获取您的头像</view>

          <button class="primary-btn wechat-btn" bindtap="wechatLogin" loading="{{loading}}" disabled="{{loading}}">
            <view class="wechat-icon-small"></view>
            {{loading ? '登录中...' : '微信一键登录'}}
          </button>
        </view>
      </block>
    </view>
  </view>

  <view class="login-footer">
    <text class="footer-text">登录即表示同意</text>
    <text class="link-text">《用户协议》</text>
    <text class="footer-text">和</text>
    <text class="link-text">《隐私政策》</text>
  </view>
</view>
