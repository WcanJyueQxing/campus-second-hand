<view class="login-page">
  <!-- Logo 区域 -->
  <view class="logo-area">
    <view class="logo-icon">S</view>
    <view class="app-name">Second Hub</view>
    <view class="app-desc">校园二手交易平台</view>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <!-- 标签切换 -->
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 'account' ? 'active' : ''}}" bindtap="switchTab" data-tab="account">账号登录</view>
      <view class="tab-item {{currentTab === 'register' ? 'active' : ''}}" bindtap="switchTab" data-tab="register">注册</view>
      <view class="tab-item {{currentTab === 'wechat' ? 'active' : ''}}" bindtap="switchTab" data-tab="wechat">微信登录</view>
    </view>

    <!-- 表单区域 -->
    <view class="form-area">
      <block wx:if="{{currentTab === 'account'}}">
        <!-- 用户名输入框 -->
        <view class="input-item">
          <view class="input-icon">
            <view class="icon-user"></view>
          </view>
          <input class="input-field" placeholder="请输入用户名/手机号" value="{{account}}" bindinput="onAccountInput" disabled="{{loading}}" />
        </view>

        <!-- 密码输入框 -->
        <view class="input-item">
          <view class="input-icon">
            <view class="icon-lock"></view>
          </view>
          <input class="input-field" placeholder="请输入密码" password value="{{password}}" bindinput="onPasswordInput" disabled="{{loading}}" />
        </view>

        <!-- 验证码行 -->
        <view class="captcha-row">
          <view class="input-item captcha-input">
            <view class="input-icon">
              <view class="icon-verification"></view>
            </view>
            <input class="input-field" placeholder="请输入验证码" value="{{captchaCode}}" bindinput="onCaptchaInput" disabled="{{loading}}" />
          </view>
          <view class="captcha-img-wrapper" bindtap="refreshCaptcha">
            <image class="captcha-img" src="{{captchaBase64}}" mode="widthFix" wx:if="{{captchaBase64}}" />
            <view class="captcha-placeholder" wx:else>加载中...</view>
          </view>
        </view>

        <!-- 记住密码 -->
        <view class="remember-item">
          <checkbox-group bindchange="onRememberChange">
            <label class="remember-label">
              <checkbox value="remember" checked="{{remember}}" color="#409eff" />
              <text class="remember-text">记住密码</text>
            </label>
          </checkbox-group>
        </view>

        <!-- 登录按钮 -->
        <button class="login-btn" bindtap="accountLogin" loading="{{loading}}" disabled="{{loading}}">{{loading ? '登录中...' : '登录'}}</button>
      </block>

      <block wx:if="{{currentTab === 'register'}}">
        <!-- 用户名输入框 -->
        <view class="nickname-input-wrap">
          <view class="input-icon">
            <view class="icon-user"></view>
          </view>
          <input class="nickname-input" placeholder="请输入用户名" value="{{registerForm.username}}" bindinput="onRegisterUsernameInput" disabled="{{loading}}" />
          <text class="random-btn" bindtap="generateRandomRegisterName">{{loading ? '生成中...' : '随机'}}</text>
        </view>

        <!-- 密码输入框 -->
        <view class="input-item">
          <view class="input-icon">
            <view class="icon-lock"></view>
          </view>
          <input class="input-field" placeholder="请输入密码" password value="{{registerForm.password}}" bindinput="onRegisterPasswordInput" disabled="{{loading}}" />
        </view>

        <!-- 确认密码输入框 -->
        <view class="input-item">
          <view class="input-icon">
            <view class="icon-lock"></view>
          </view>
          <input class="input-field" placeholder="请确认密码" password value="{{registerForm.confirmPassword}}" bindinput="onRegisterConfirmPasswordInput" disabled="{{loading}}" />
        </view>

        <!-- 验证码行 -->
        <view class="captcha-row">
          <view class="input-item captcha-input">
            <view class="input-icon">
              <view class="icon-verification"></view>
            </view>
            <input class="input-field" placeholder="请输入验证码" value="{{registerForm.captchaCode}}" bindinput="onRegisterCaptchaInput" disabled="{{loading}}" />
          </view>
          <view class="captcha-img-wrapper" bindtap="refreshCaptcha">
            <image class="captcha-img" src="{{captchaBase64}}" mode="widthFix" wx:if="{{captchaBase64}}" />
            <view class="captcha-placeholder" wx:else>加载中...</view>
          </view>
        </view>

        <!-- 注册按钮 -->
        <button class="login-btn" bindtap="register" loading="{{loading}}" disabled="{{loading}}">{{loading ? '注册中...' : '注册'}}</button>
      </block>

      <block wx:if="{{currentTab === 'wechat'}}">
        <view class="wechat-login">
          <view class="wechat-hint">一键授权，快速登录</view>
          <view class="nickname-input-wrap">
            <view class="input-icon">
              <view class="icon-user"></view>
            </view>
            <input class="nickname-input" placeholder="请输入昵称（选填）" value="{{nickname}}" bindinput="onNicknameInput" disabled="{{loading}}" />
            <text class="random-btn" bindtap="generateRandomName">{{loading ? '生成中...' : '随机'}}</text>
          </view>
          <view class="avatar-hint">微信授权将自动获取您的头像</view>
          <button class="login-btn wechat-btn" bindtap="wechatLogin" loading="{{loading}}" disabled="{{loading}}">
            <view class="wechat-icon"></view>
            {{loading ? '登录中...' : '微信一键登录'}}
          </button>
        </view>
      </block>
    </view>
  </view>
</view>